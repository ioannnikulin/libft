#include <stdlib.h>

void	*ft_memmove(void *dest, void *src, size_t n);

struct testcase
{
	size_t	global_sz;
	char	*src;
	size_t	src_start;
	size_t	tocopy;
	size_t	dst_start;
	unsigned char	nullify;
	// 0 - both dest and src are valid;
	// 1 - src NULL; 2 - dest NULL; 3 - both NULL
}

void	*ft_memmove_test_prep(testcase t)
{
	assert(t.global_sz >= t.src_start + t.tocopy);
	assert(t.global_sz >= t.dst_start + t.tocopy);
	char * res = calloc(t.global_sz, 1);
	assert(res != NULL);
	memmove(&res[t.src_start], t.src, t.tocopy);
	for (int j = 0; j < t.src_start; j ++)
		assert(res[j] == 0);
	assert(strncmp(&res[t.src_start], t.src, t.tocopy) == 0);
	for (int j = t.src_start + t.tocopy; j < t.global_sz; j ++)
		assert(res[j] == 0);
	return (res);
}

void	ft_memmove_test(void)
{
	const int SZ = 9;
	testcase t[SZ];
	t[0] = (testcase){10, "abc", 1, 2, 6, 0};
	t[1] = (testcase){10, "abc", 1, 0, 6, 0};
	t[2] = (testcase){10, "abc", 1, 4, 6, 0};
	t[3] = (testcase){10, "abc", 1, 4, 2, 0};
	t[4] = (testcase){10, "abc", 4, 4, 2, 0};
	t[5] = (testcase){10, "", 4, 4, 2, 0};
	t[6] = (testcase){10, "abc", 1, 2, 6, 1};
	t[7] = (testcase){10, "abc", 1, 2, 6, 2};
	t[8] = (testcase){10, "abc", 1, 2, 6, 3};
	for (int i = 0; i < SZ; i ++)
	{
		char * custom_src = ft_memmove_test_prep(t[i]);
		char * std_src = ft_memmove_test_prep(t[i]);
		char * custom_res = ft_memmove( \
			(t[i].nullify & 1 > 0 ? NULL : &custom_src[t[i].dest_start]), \
			(t[i].nullify & 2 > 0 ? NULL : &custom_src[t[i].src_start]), \
			t[i].tocopy);
		char * std_res = memmove( \
			(t[i].nullify & 1 > 0 ? NULL : &std_src[t[i].dest_start]), \
			(t[i].nullify & 2 > 0 ? NULL : &std_src[t[i].src_start]), \
			t[i].tocopy);
		if (custom_res == std_res) // NULL
		{
			free(custom_src);
			free(std_src);
			continue;
		}
		for (int j = 0; j < t[i].global_sz; j ++)
			assert(custom_res[j] == std_res[j]);
		assert(custom_src == custom_res);
		free(custom_src);
		free(std_src);
	}
}
