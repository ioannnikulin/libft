#include <stdlib.h>

void	*ft_bzero(void *s, size_t n);

void	*ft_bzero_test_prep(int sz)
{
	char * res = calloc(sz + 2, 1);
	assert(res != NULL);
	for (int j = 0; j < sz + 2; j ++)
		assert(res[j] == 0);
	memset(res, '1', sz + 2);
	for (int j = 0; j < sz + 2; j ++)
		assert(res[j] == '1');
	return (res);
}

void	ft_memset_test(void)
{
	const int SZ = 3;
	size_t t[SZ] = {3, 1, 0};
	for (int i = 0; i < SZ; i ++)
	{
		char * custom_src = ft_bzero_test_prep(t[i]);
		char * std_src = ft_bzero_test_prep(t[i]);
		char * custom_res = ft_bzero(custom_src, t[i]);
		char * std_res = bzero(std_src, t[i]);
		for (int j = 0; j < t[i] + 2; j ++)
			assert(custom_res[j] == std_res[j]);
		assert(custom_src == custom_res);
		free(std_src);
		free(custom_src);
	}
	char * custom_res = ft_bzero(NULL, 5);
	char * std_res = bzero(NULL, 5);
	if (custom_res != std_res)
		for (int j = 0; j < t[i] + 2; j ++)
			assert(custom_res[j] == std_res[j]);
	assert(custom_src == custom_res);
	free(std_src);
	free(custom_src);
}
