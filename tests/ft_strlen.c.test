#include <string.h>

int	ft_strlen(char *c);

void	ft_strlen_test(void)
{
	const int SZ = 4;
	char ** tests = {"hello", "¤", "", NULL);
	for (int i = 0; i <  SZ; i ++)
		assert(ft_strlen(tests[i]) == strlen(tests[i]));
}
